<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ApiRoute" stopProcessing="true">
          <match url="^api/?$" />
          <action type="Rewrite" url="/api.php" />
        </rule>

        <rule name="ApiPhpPassThrough" stopProcessing="true">
          <match url="^api\.php$" />
          <action type="None" />
        </rule>
      </rules>
    </rewrite>

    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment=".git" />
          <add segment="private" />
          <add segment="app" />
          <add segment="database" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <defaultDocument>
      <files>
        <clear />
        <add value="api.php" />
      </files>
    </defaultDocument>
  </system.webServer>
</configuration>
